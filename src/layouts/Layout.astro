---
import '@fontsource-variable/inter';
import '@fontsource-variable/noto-sans-jp';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const { 
	title = 'みにっつのブログ', 
	description = 'みにっつの超個人的備忘録。見ていてストレスのないシンプルな個人ブログ。',
	image = '/placeholder.jpg'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<!-- Fonts are loaded locally via Fontsource Variable -->
	</head>
	<body class="bg-stone-50 text-stone-900 font-sans antialiased min-h-screen flex flex-col selection:bg-stone-200">
		<header class="border-b border-stone-200/80 bg-white/70 backdrop-blur-xs sticky top-0 z-40">
			<div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
				<a href="/" class="text-xl font-bold tracking-tight text-stone-900 hover:text-stone-700 transition-colors duration-200">
					みにっつ
				</a>
				<nav class="flex items-center gap-6">
					<a href="/" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors duration-200">Home</a>
					<a href="/posts" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors duration-200">Posts</a>
					<a href="/about" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors duration-200">About</a>
				</nav>
			</div>
		</header>

		<main class="flex-1 max-w-4xl w-full mx-auto px-6 py-12">
			<slot />
		</main>

		<footer class="border-t border-stone-200/80 bg-stone-100/50 py-8 mt-auto">
			<div class="max-w-4xl mx-auto px-6 text-center sm:text-left text-xs text-stone-500">
				<p>&copy; {new Date().getFullYear()} みにっつ. All rights reserved.</p>
			</div>
		</footer>
	</body>
</html>

