---
import '@fontsource-variable/inter';
import '@fontsource-variable/noto-sans-jp';
import '../styles/global.css';
import { Icon } from 'astro-icon/components';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	markdownUrl?: string;
}

const { 
	title = 'みにっつのブログ', 
	description = 'みにっつの超個人的備忘録。見ていてストレスのないシンプルな個人ブログ。',
	image = '/placeholder.jpg',
	markdownUrl,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
const currentPath = Astro.url.pathname;
const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/posts', label: 'Posts' },
	{ href: '/tags', label: 'Tags' },
	{ href: '/tools', label: 'Tools' },
	{ href: '/about', label: 'About' },
];
const isCurrentPage = (href: string) => href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<script is:inline>
			try {
				const hue = localStorage.getItem('theme-hue');
				if (hue !== null && Number.isFinite(Number(hue))) {
					document.documentElement.style.setProperty('--theme-hue', String(Math.min(360, Math.max(0, Number(hue)))));
				}
			} catch {}
		</script>

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL} />
		{markdownUrl && <link rel="alternate" type="text/markdown" href={new URL(markdownUrl, Astro.url)} />}

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<!-- Fonts are loaded locally via Fontsource Variable -->
		<style>
			.mobile-nav-panel {
				max-height: 0;
				opacity: 0;
				overflow: hidden;
				pointer-events: none;
				transform: translateY(-0.375rem);
				transition:
					max-height 220ms cubic-bezier(0.22, 1, 0.36, 1),
					opacity 160ms ease,
					transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
			}

			.mobile-nav-panel[data-state='open'] {
				max-height: calc(100dvh - 4rem);
				opacity: 1;
				overflow-y: auto;
				overscroll-behavior: contain;
				pointer-events: auto;
				transform: translateY(0);
			}

			.mobile-nav-panel a {
				opacity: 0;
				transform: translateY(-0.25rem);
				transition:
					opacity 160ms ease,
					transform 180ms cubic-bezier(0.22, 1, 0.36, 1),
					background-color 150ms ease,
					color 150ms ease;
			}

			.mobile-nav-panel[data-state='open'] a {
				opacity: 1;
				transform: translateY(0);
			}

			.mobile-nav-panel[data-state='open'] a:nth-child(2) {
				transition-delay: 25ms;
			}

			.mobile-nav-panel[data-state='open'] a:nth-child(3) {
				transition-delay: 50ms;
			}

			.mobile-nav-panel[data-state='open'] a:nth-child(4) {
				transition-delay: 75ms;
			}

			[data-menu-toggle] [data-menu-open-icon],
			[data-menu-toggle] [data-menu-close-icon] {
				transition:
					opacity 150ms ease,
					transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
			}

			[data-menu-toggle] [data-menu-close-icon] {
				opacity: 0;
				position: absolute;
				transform: rotate(-90deg) scale(0.85);
			}

			[data-menu-toggle][aria-expanded='true'] [data-menu-open-icon] {
				opacity: 0;
				transform: rotate(90deg) scale(0.85);
			}

			[data-menu-toggle][aria-expanded='true'] [data-menu-close-icon] {
				opacity: 1;
				transform: rotate(0deg) scale(1);
			}

			.theme-picker-panel {
				position: absolute;
				inset-block-start: calc(100% + 0.75rem);
				inset-inline-end: 0;
				width: 15rem;
			}

			[data-theme-chevron] {
				transition: rotate 180ms cubic-bezier(0.22, 1, 0.36, 1);
			}

			[data-mobile-theme][open] [data-theme-chevron] {
				rotate: 180deg;
			}

			@media (prefers-reduced-motion: reduce) {
				.mobile-nav-panel,
				.mobile-nav-panel a,
				[data-menu-toggle] [data-menu-open-icon],
				[data-menu-toggle] [data-menu-close-icon],
				[data-theme-chevron] {
					transition: none;
				}
			}
		</style>
	</head>
	<body class="bg-stone-50 text-stone-900 font-sans antialiased min-h-screen flex flex-col selection:bg-stone-200">
		<header class="border-b border-stone-200/80 bg-white/70 backdrop-blur-xs sticky top-0 z-40">
			<div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
				<a href="/" class="text-xl font-bold tracking-tight text-stone-900 hover:text-stone-700 transition-colors duration-200">
					みにっつ
				</a>
				<div class="hidden md:flex items-center gap-3">
				<nav class="flex items-center gap-0.5 rounded-lg border border-stone-200/70 bg-stone-100/70 p-1" aria-label="メインナビゲーション">
					{navItems.map((item) => (
						<a
							href={item.href}
							aria-current={isCurrentPage(item.href) ? 'page' : undefined}
							class:list={[
								'inline-flex min-h-9 items-center rounded-md px-2.5 text-[0.8125rem] font-medium transition-colors duration-150 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-stone-500',
								isCurrentPage(item.href)
									? 'bg-white text-stone-900 shadow-[0_1px_2px_rgba(0,0,0,0.06)]'
									: 'text-stone-600 hover:bg-white/60 hover:text-stone-900',
							]}
						>
							{item.label}
						</a>
					))}
				</nav>
				<details class="relative" data-theme-picker>
					<summary class="list-none cursor-pointer inline-flex h-9 w-9 items-center justify-center rounded-md border border-stone-200 bg-white text-stone-600 transition-colors hover:border-stone-300 hover:text-stone-900 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-stone-500" aria-label="テーマカラーを変更">
						<Icon name="tabler:palette" class="h-4.5 w-4.5" aria-hidden="true" />
					</summary>
					<div class="theme-picker-panel rounded-lg border border-stone-200 bg-white p-4 shadow-[0_6px_20px_rgba(0,0,0,0.08)]">
						<label class="block text-xs font-medium text-stone-700" for="theme-hue-desktop">テーマの色相 <output class="float-right tabular-nums text-stone-500" data-hue-output>55°</output></label>
						<div class="theme-hue-preview mt-2 h-2 rounded-full" aria-hidden="true"></div>
						<input id="theme-hue-desktop" class="theme-hue-range mt-1 block w-full" type="range" min="0" max="360" value="55" data-hue-input />
						<button class="mt-2 text-xs text-stone-500 underline decoration-stone-300 underline-offset-4 hover:text-stone-900" type="button" data-hue-reset>初期色に戻す</button>
					</div>
				</details>
				</div>
				<button
					type="button"
					class="md:hidden relative inline-flex h-10 w-10 items-center justify-center rounded-md border border-stone-200 bg-white text-stone-700 transition-colors duration-150 hover:border-stone-300 hover:bg-stone-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-400 focus-visible:ring-offset-2"
					aria-label="メニューを開く"
					aria-controls="mobile-navigation"
					aria-expanded="false"
					data-menu-toggle
				>
					<Icon name="tabler:menu-2" class="h-5 w-5" aria-hidden="true" data-menu-open-icon />
					<Icon name="tabler:x" class="h-5 w-5" aria-hidden="true" data-menu-close-icon />
				</button>
			</div>
			<nav
				id="mobile-navigation"
				class="mobile-nav-panel md:hidden border-t border-stone-200/80 bg-white/95 px-6"
				aria-label="モバイルナビゲーション"
				aria-hidden="true"
				data-state="closed"
				data-mobile-nav
				inert
			>
				<div class="max-w-4xl mx-auto grid gap-1 py-3">
					{navItems.map((item) => (
						<a
							href={item.href}
							aria-current={isCurrentPage(item.href) ? 'page' : undefined}
							class:list={[
								'rounded-md px-3 py-2 text-sm font-medium transition-colors duration-150',
								isCurrentPage(item.href) ? 'bg-stone-100 text-stone-900' : 'text-stone-700 hover:bg-stone-100 hover:text-stone-900',
							]}
						>
							{item.label}
						</a>
					))}
					<details class="mt-2 border-t border-stone-200 pt-2" data-mobile-theme>
						<summary class="flex min-h-10 cursor-pointer list-none items-center gap-2 rounded-md px-3 text-sm font-medium text-stone-700 hover:bg-stone-100 hover:text-stone-900 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-stone-500">
							<Icon name="tabler:palette" class="h-4 w-4 text-stone-500" aria-hidden="true" />
							<span>テーマカラー</span>
							<output class="ml-auto tabular-nums text-xs font-normal text-stone-500" data-hue-output>55°</output>
							<Icon name="tabler:chevron-down" class="h-4 w-4 text-stone-400" aria-hidden="true" data-theme-chevron />
						</summary>
						<div class="mx-3 mb-2 mt-1 rounded-lg border border-stone-200 bg-stone-50/70 p-3">
							<label class="sr-only" for="theme-hue-mobile">テーマの色相</label>
							<div class="theme-hue-preview h-2 rounded-full" aria-hidden="true"></div>
							<input id="theme-hue-mobile" class="theme-hue-range mt-1 block w-full" type="range" min="0" max="360" value="55" data-hue-input />
							<button class="mt-1 min-h-8 text-xs text-stone-500 underline decoration-stone-300 underline-offset-4 hover:text-stone-900" type="button" data-hue-reset>初期色に戻す</button>
						</div>
					</details>
				</div>
			</nav>
		</header>

		<main class="flex-1 max-w-4xl w-full mx-auto px-6 py-12">
			<slot />
		</main>

		<footer class="border-t border-stone-200/80 bg-stone-100/50 py-8 mt-auto">
			<div class="max-w-4xl mx-auto px-6 text-center sm:text-left text-xs text-stone-500">
				<p>&copy; {new Date().getFullYear()} みにっつ. All rights reserved.</p>
			</div>
		</footer>
		<script>
			const defaultHue = 55;
			const hueInputs = document.querySelectorAll('[data-hue-input]');
			const hueOutputs = document.querySelectorAll('[data-hue-output]');

			function setHue(value, persist = true) {
				const hue = Math.min(360, Math.max(0, Number(value) || 0));
				document.documentElement.style.setProperty('--theme-hue', String(hue));
				hueInputs.forEach((input) => {
					if (input instanceof HTMLInputElement) input.value = String(hue);
				});
				hueOutputs.forEach((output) => {
					output.textContent = `${hue}°`;
				});
				if (persist) {
					try { localStorage.setItem('theme-hue', String(hue)); } catch {}
				}
			}

			const initialHue = Number.parseFloat(getComputedStyle(document.documentElement).getPropertyValue('--theme-hue'));
			setHue(Number.isFinite(initialHue) ? initialHue : defaultHue, false);
			hueInputs.forEach((input) => input.addEventListener('input', (event) => {
				if (event.currentTarget instanceof HTMLInputElement) setHue(event.currentTarget.value);
			}));
			document.querySelectorAll('[data-hue-reset]').forEach((button) => {
				button.addEventListener('click', () => {
					try { localStorage.removeItem('theme-hue'); } catch {}
					setHue(defaultHue, false);
				});
			});

			const themePickers = document.querySelectorAll('[data-theme-picker]');
			document.addEventListener('pointerdown', (event) => {
				const eventPath = event.composedPath();
				themePickers.forEach((picker) => {
					if (picker instanceof HTMLDetailsElement && picker.open && !eventPath.includes(picker)) {
						picker.open = false;
					}
				});
			});

			const toggle = document.querySelector('[data-menu-toggle]');
			const nav = document.querySelector('[data-mobile-nav]');

			function setMenuOpen(open) {
				if (!(toggle instanceof HTMLButtonElement) || !(nav instanceof HTMLElement)) return;

				toggle.setAttribute('aria-expanded', String(open));
				toggle.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');
				nav.dataset.state = open ? 'open' : 'closed';
				nav.setAttribute('aria-hidden', String(!open));
				nav.toggleAttribute('inert', !open);
				if (!open) {
					const mobileTheme = nav.querySelector('[data-mobile-theme]');
					if (mobileTheme instanceof HTMLDetailsElement) mobileTheme.open = false;
				}
			}

			toggle?.addEventListener('click', () => {
				const isOpen = toggle.getAttribute('aria-expanded') === 'true';
				setMenuOpen(!isOpen);
			});

			nav?.addEventListener('click', (event) => {
				if (event.target instanceof HTMLAnchorElement) {
					setMenuOpen(false);
				}
			});

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					setMenuOpen(false);
				}
			});
		</script>
	</body>
</html>
