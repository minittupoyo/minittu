---
import '@fontsource-variable/inter';
import '@fontsource-variable/noto-sans-jp';
import '../styles/global.css';
import { Icon } from 'astro-icon/components';

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const { 
	title = 'みにっつのブログ', 
	description = 'みにっつの超個人的備忘録。見ていてストレスのないシンプルな個人ブログ。',
	image = '/placeholder.jpg'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<!-- Fonts are loaded locally via Fontsource Variable -->
		<style>
			.mobile-nav-panel {
				max-height: 0;
				opacity: 0;
				overflow: hidden;
				pointer-events: none;
				transform: translateY(-0.375rem);
				transition:
					max-height 220ms cubic-bezier(0.22, 1, 0.36, 1),
					opacity 160ms ease,
					transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
			}

			.mobile-nav-panel[data-state='open'] {
				max-height: 16rem;
				opacity: 1;
				pointer-events: auto;
				transform: translateY(0);
			}

			.mobile-nav-panel a {
				opacity: 0;
				transform: translateY(-0.25rem);
				transition:
					opacity 160ms ease,
					transform 180ms cubic-bezier(0.22, 1, 0.36, 1),
					background-color 150ms ease,
					color 150ms ease;
			}

			.mobile-nav-panel[data-state='open'] a {
				opacity: 1;
				transform: translateY(0);
			}

			.mobile-nav-panel[data-state='open'] a:nth-child(2) {
				transition-delay: 25ms;
			}

			.mobile-nav-panel[data-state='open'] a:nth-child(3) {
				transition-delay: 50ms;
			}

			.mobile-nav-panel[data-state='open'] a:nth-child(4) {
				transition-delay: 75ms;
			}

			[data-menu-toggle] [data-menu-open-icon],
			[data-menu-toggle] [data-menu-close-icon] {
				transition:
					opacity 150ms ease,
					transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
			}

			[data-menu-toggle] [data-menu-close-icon] {
				opacity: 0;
				position: absolute;
				transform: rotate(-90deg) scale(0.85);
			}

			[data-menu-toggle][aria-expanded='true'] [data-menu-open-icon] {
				opacity: 0;
				transform: rotate(90deg) scale(0.85);
			}

			[data-menu-toggle][aria-expanded='true'] [data-menu-close-icon] {
				opacity: 1;
				transform: rotate(0deg) scale(1);
			}

			@media (prefers-reduced-motion: reduce) {
				.mobile-nav-panel,
				.mobile-nav-panel a,
				[data-menu-toggle] [data-menu-open-icon],
				[data-menu-toggle] [data-menu-close-icon] {
					transition: none;
				}
			}
		</style>
	</head>
	<body class="bg-stone-50 text-stone-900 font-sans antialiased min-h-screen flex flex-col selection:bg-stone-200">
		<header class="border-b border-stone-200/80 bg-white/70 backdrop-blur-xs sticky top-0 z-40">
			<div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
				<a href="/" class="text-xl font-bold tracking-tight text-stone-900 hover:text-stone-700 transition-colors duration-200">
					みにっつ
				</a>
				<nav class="hidden md:flex items-center gap-6" aria-label="メインナビゲーション">
					<a href="/" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors duration-200">Home</a>
					<a href="/posts" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors duration-200">Posts</a>
					<a href="/tags" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors duration-200">Tags</a>
					<a href="/tools" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors duration-200">Tools</a>
					<a href="/about" class="text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors duration-200">About</a>
				</nav>
				<button
					type="button"
					class="md:hidden relative inline-flex h-10 w-10 items-center justify-center rounded-md border border-stone-200 bg-white text-stone-700 transition-colors duration-150 hover:border-stone-300 hover:bg-stone-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-400 focus-visible:ring-offset-2"
					aria-label="メニューを開く"
					aria-controls="mobile-navigation"
					aria-expanded="false"
					data-menu-toggle
				>
					<Icon name="tabler:menu-2" class="h-5 w-5" aria-hidden="true" data-menu-open-icon />
					<Icon name="tabler:x" class="h-5 w-5" aria-hidden="true" data-menu-close-icon />
				</button>
			</div>
			<nav
				id="mobile-navigation"
				class="mobile-nav-panel md:hidden border-t border-stone-200/80 bg-white/95 px-6"
				aria-label="モバイルナビゲーション"
				aria-hidden="true"
				data-state="closed"
				data-mobile-nav
				inert
			>
				<div class="max-w-4xl mx-auto grid gap-1 py-3">
					<a href="/" class="rounded-md px-3 py-2 text-sm font-medium text-stone-700 hover:bg-stone-100 hover:text-stone-900 transition-colors duration-150">Home</a>
					<a href="/posts" class="rounded-md px-3 py-2 text-sm font-medium text-stone-700 hover:bg-stone-100 hover:text-stone-900 transition-colors duration-150">Posts</a>
					<a href="/tags" class="rounded-md px-3 py-2 text-sm font-medium text-stone-700 hover:bg-stone-100 hover:text-stone-900 transition-colors duration-150">Tags</a>
					<a href="/tools" class="rounded-md px-3 py-2 text-sm font-medium text-stone-700 hover:bg-stone-100 hover:text-stone-900 transition-colors duration-150">Tools</a>
					<a href="/about" class="rounded-md px-3 py-2 text-sm font-medium text-stone-700 hover:bg-stone-100 hover:text-stone-900 transition-colors duration-150">About</a>
				</div>
			</nav>
		</header>

		<main class="flex-1 max-w-4xl w-full mx-auto px-6 py-12">
			<slot />
		</main>

		<footer class="border-t border-stone-200/80 bg-stone-100/50 py-8 mt-auto">
			<div class="max-w-4xl mx-auto px-6 text-center sm:text-left text-xs text-stone-500">
				<p>&copy; {new Date().getFullYear()} みにっつ. All rights reserved.</p>
			</div>
		</footer>
		<script>
			const toggle = document.querySelector('[data-menu-toggle]');
			const nav = document.querySelector('[data-mobile-nav]');

			function setMenuOpen(open) {
				if (!(toggle instanceof HTMLButtonElement) || !(nav instanceof HTMLElement)) return;

				toggle.setAttribute('aria-expanded', String(open));
				toggle.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');
				nav.dataset.state = open ? 'open' : 'closed';
				nav.setAttribute('aria-hidden', String(!open));
				nav.toggleAttribute('inert', !open);
			}

			toggle?.addEventListener('click', () => {
				const isOpen = toggle.getAttribute('aria-expanded') === 'true';
				setMenuOpen(!isOpen);
			});

			nav?.addEventListener('click', (event) => {
				if (event.target instanceof HTMLAnchorElement) {
					setMenuOpen(false);
				}
			});

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					setMenuOpen(false);
				}
			});
		</script>
	</body>
</html>
