---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout title="ページが見つかりません | みにっつのブログ" description="お探しのページは見つかりませんでした。" noindex>
	<div class="max-w-2xl mx-auto py-16 text-center">
		<p class="text-sm font-mono text-stone-400">404</p>
		<h1 class="mt-3 text-3xl font-extrabold tracking-tight text-stone-900">ページが見つかりません</h1>
		<p class="mt-4 text-sm leading-relaxed text-stone-600">
			URLが変更されたか、ページが削除された可能性があります。
		</p>
		<div class="mt-8 flex flex-wrap justify-center gap-3">
			<a href="/" class="inline-flex items-center gap-2 rounded-lg bg-stone-900 px-4 py-2.5 text-sm font-semibold text-white hover:bg-stone-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-400 focus-visible:ring-offset-2">
				<Icon name="tabler:home" class="h-4 w-4" aria-hidden="true" />
				ホームへ戻る
			</a>
			<a href="/posts" class="inline-flex items-center gap-2 rounded-lg border border-stone-200 bg-white px-4 py-2.5 text-sm font-semibold text-stone-700 hover:border-stone-300 hover:bg-stone-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-400 focus-visible:ring-offset-2">
				<Icon name="tabler:article" class="h-4 w-4" aria-hidden="true" />
				記事一覧を見る
			</a>
		</div>
	</div>
</Layout>
