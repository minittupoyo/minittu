---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import ToolHeading from '../components/tools/ToolHeading.astro';
import ToolStat from '../components/tools/ToolStat.astro';

const tools = [
	{ id: 'json', label: 'JSON整形', icon: 'tabler:braces', description: 'JSONを読みやすく整形・圧縮します。' },
	{ id: 'url', label: 'URL変換', icon: 'tabler:link', description: '文字列をURL用にエンコード・デコードします。' },
	{ id: 'timestamp', label: 'Unix時刻', icon: 'tabler:clock', description: 'Unix時刻と日時を相互に変換します。' },
	{ id: 'counter', label: '文字数', icon: 'tabler:text-size', description: '文字数・行数・バイト数を数えます。' },
	{ id: 'checksum', label: 'WASMチェックサム', icon: 'tabler:assembly', description: 'テキストやファイルのXXHashを高速に計算します。' },
];
---

<Layout title="便利ツール | みにっつのブログ" description="JSON整形、URL変換、Unix時刻変換、文字数カウントをブラウザだけで使える便利ツール集です。">
	<div class="space-y-10">
		<header class="py-6 border-b border-stone-200/60">
			<h1 class="text-3xl font-extrabold text-stone-900 tracking-tight">便利ツール</h1>
			<p class="mt-3 max-w-2xl text-sm leading-relaxed text-stone-500">
				ちょっとした変換や確認に使う道具置き場です。入力内容は外部へ送信されません。
			</p>
		</header>

		<nav aria-label="ツール一覧" class="flex flex-wrap gap-2">
			{tools.map((tool) => (
				<a href={`#${tool.id}`} class="inline-flex items-center gap-2 rounded-md border border-stone-200 bg-white px-3 py-2 text-sm font-medium text-stone-600 transition-colors hover:border-stone-300 hover:text-stone-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-400 focus-visible:ring-offset-2">
					<Icon name={tool.icon} class="h-4 w-4" aria-hidden="true" />
					{tool.label}
				</a>
			))}
		</nav>

		<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
			<section id="json" class="scroll-mt-24 rounded-xl border border-stone-200/80 bg-white p-5 sm:p-6" data-json-tool>
				<ToolHeading tool={tools[0]} />
				<label for="json-input" class="mt-6 block text-xs font-bold text-stone-500">JSON</label>
				<textarea id="json-input" rows="8" spellcheck="false" placeholder={'{"name":"minittu"}'} class="mt-2 w-full resize-y rounded-md border border-stone-200 bg-stone-50 p-3 font-mono text-sm leading-relaxed text-stone-800 outline-none transition-colors placeholder:text-stone-400 focus:border-stone-400 focus:ring-2 focus:ring-stone-200"></textarea>
				<div class="mt-3 flex flex-wrap gap-2">
					<button type="button" data-json-format class="tool-button">整形</button>
					<button type="button" data-json-minify class="tool-button">圧縮</button>
					<button type="button" data-copy-target="json-input" class="tool-button-secondary">コピー</button>
				</div>
				<p data-json-status class="mt-3 min-h-5 text-xs text-stone-500" role="status" aria-live="polite"></p>
			</section>

			<section id="url" class="scroll-mt-24 rounded-xl border border-stone-200/80 bg-white p-5 sm:p-6" data-url-tool>
				<ToolHeading tool={tools[1]} />
				<label for="url-input" class="mt-6 block text-xs font-bold text-stone-500">変換する文字列</label>
				<textarea id="url-input" rows="8" spellcheck="false" placeholder="みにっつのブログ" class="mt-2 w-full resize-y rounded-md border border-stone-200 bg-stone-50 p-3 font-mono text-sm leading-relaxed text-stone-800 outline-none transition-colors placeholder:text-stone-400 focus:border-stone-400 focus:ring-2 focus:ring-stone-200"></textarea>
				<div class="mt-3 flex flex-wrap gap-2">
					<button type="button" data-url-encode class="tool-button">エンコード</button>
					<button type="button" data-url-decode class="tool-button">デコード</button>
					<button type="button" data-copy-target="url-input" class="tool-button-secondary">コピー</button>
				</div>
				<p data-url-status class="mt-3 min-h-5 text-xs text-stone-500" role="status" aria-live="polite"></p>
			</section>

			<section id="timestamp" class="scroll-mt-24 rounded-xl border border-stone-200/80 bg-white p-5 sm:p-6" data-time-tool>
				<ToolHeading tool={tools[2]} />
				<div class="mt-6 space-y-4">
					<div>
						<label for="unix-input" class="block text-xs font-bold text-stone-500">Unix時刻（秒）</label>
						<div class="mt-2 flex gap-2">
							<input id="unix-input" inputmode="numeric" class="min-w-0 flex-1 rounded-md border border-stone-200 bg-stone-50 px-3 py-2 font-mono text-sm text-stone-800 outline-none focus:border-stone-400 focus:ring-2 focus:ring-stone-200" />
							<button type="button" data-time-now class="tool-button-secondary shrink-0">現在</button>
						</div>
					</div>
					<div>
						<label for="date-input" class="block text-xs font-bold text-stone-500">ローカル日時</label>
						<input id="date-input" type="datetime-local" step="1" class="mt-2 w-full rounded-md border border-stone-200 bg-stone-50 px-3 py-2 text-sm text-stone-800 outline-none focus:border-stone-400 focus:ring-2 focus:ring-stone-200" />
					</div>
				</div>
				<p data-time-status class="mt-3 min-h-5 text-xs text-stone-500" role="status" aria-live="polite"></p>
			</section>

			<section id="counter" class="scroll-mt-24 rounded-xl border border-stone-200/80 bg-white p-5 sm:p-6" data-counter-tool>
				<ToolHeading tool={tools[3]} />
				<label for="counter-input" class="mt-6 block text-xs font-bold text-stone-500">数えるテキスト</label>
				<textarea id="counter-input" rows="5" placeholder="ここにテキストを入力" class="mt-2 w-full resize-y rounded-md border border-stone-200 bg-stone-50 p-3 text-sm leading-relaxed text-stone-800 outline-none transition-colors placeholder:text-stone-400 focus:border-stone-400 focus:ring-2 focus:ring-stone-200"></textarea>
				<dl class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4" aria-live="polite">
					<ToolStat label="文字" output="counter-chars" />
					<ToolStat label="空白除外" output="counter-no-space" />
					<ToolStat label="行" output="counter-lines" />
					<ToolStat label="バイト" output="counter-bytes" />
				</dl>
			</section>

			<section id="checksum" class="scroll-mt-24 rounded-xl border border-stone-200/80 bg-white p-5 sm:p-6 lg:col-span-2" data-hash-tool>
				<div class="flex flex-col gap-6 lg:flex-row lg:items-start">
					<div class="lg:w-1/2">
						<ToolHeading tool={tools[4]} />
						<p class="mt-4 text-xs leading-relaxed text-stone-500">
							暗号用途ではなく、ファイルが同一かどうかの高速な確認向けです。処理はWebAssemblyでブラウザ内だけで行います。
						</p>
						<div class="mt-5 flex gap-2 border-b border-stone-200" role="tablist" aria-label="入力方法">
							<button type="button" role="tab" aria-selected="true" aria-controls="hash-text-panel" id="hash-text-tab" data-hash-tab="text" class="hash-tab">テキスト</button>
							<button type="button" role="tab" aria-selected="false" aria-controls="hash-file-panel" id="hash-file-tab" data-hash-tab="file" class="hash-tab">ファイル</button>
						</div>
						<div id="hash-text-panel" role="tabpanel" aria-labelledby="hash-text-tab" data-hash-panel="text">
							<label for="hash-text-input" class="mt-4 block text-xs font-bold text-stone-500">ハッシュ化するテキスト</label>
							<textarea id="hash-text-input" rows="5" placeholder="ここにテキストを入力" class="mt-2 w-full resize-y rounded-md border border-stone-200 bg-stone-50 p-3 text-sm leading-relaxed text-stone-800 outline-none placeholder:text-stone-400 focus:border-stone-400 focus:ring-2 focus:ring-stone-200"></textarea>
						</div>
						<div id="hash-file-panel" role="tabpanel" aria-labelledby="hash-file-tab" data-hash-panel="file" hidden>
							<label for="hash-file-input" class="mt-4 block text-xs font-bold text-stone-500">ハッシュ化するファイル</label>
							<input id="hash-file-input" type="file" class="mt-2 block w-full rounded-md border border-stone-200 bg-stone-50 text-xs text-stone-600 file:mr-3 file:border-0 file:border-r file:border-stone-200 file:bg-white file:px-3 file:py-2.5 file:font-semibold file:text-stone-700 hover:file:bg-stone-100" />
						</div>
					</div>
					<div class="lg:w-1/2 lg:border-l lg:border-stone-200 lg:pl-6">
						<h3 class="text-xs font-bold uppercase tracking-wider text-stone-400">計算結果</h3>
						<dl class="mt-4 space-y-3">
							<div class="rounded-md bg-stone-50 p-3">
								<dt class="text-xs font-medium text-stone-500">XXH32</dt>
								<dd id="hash-32-output" class="mt-1 break-all font-mono text-sm font-bold text-stone-800">—</dd>
							</div>
							<div class="rounded-md bg-stone-50 p-3">
								<dt class="text-xs font-medium text-stone-500">XXH64</dt>
								<dd id="hash-64-output" class="mt-1 break-all font-mono text-sm font-bold text-stone-800">—</dd>
							</div>
						</dl>
						<p data-hash-status class="mt-3 min-h-5 text-xs text-stone-500" role="status" aria-live="polite">WASMを読み込んでいます…</p>
					</div>
				</div>
			</section>
		</div>
	</div>
</Layout>

<style>
	.tool-button, .tool-button-secondary { border-radius: .375rem; padding: .5rem .75rem; font-size: .75rem; font-weight: 600; transition: background-color 150ms, border-color 150ms, color 150ms; }
	.tool-button { background: var(--color-stone-800); color: white; }
	.tool-button:hover { background: var(--color-stone-700); }
	.tool-button-secondary { border: 1px solid var(--color-stone-200); background: white; color: var(--color-stone-600); }
	.tool-button-secondary:hover { border-color: var(--color-stone-300); color: var(--color-stone-900); }
	.tool-button:focus-visible, .tool-button-secondary:focus-visible { outline: 2px solid var(--color-stone-400); outline-offset: 2px; }
	.hash-tab { margin-bottom: -1px; border-bottom: 2px solid transparent; padding: .5rem .75rem; font-size: .75rem; font-weight: 600; color: var(--color-stone-500); }
	.hash-tab[aria-selected='true'] { border-color: var(--color-stone-800); color: var(--color-stone-900); }
	.hash-tab:focus-visible { border-radius: .25rem; outline: 2px solid var(--color-stone-400); outline-offset: 2px; }
</style>

<script>
	import createXxhash from 'xxhash-wasm';

	const byId = (id: string) => document.getElementById(id);
	const setStatus = (selector: string, message: string, error = false) => {
		const element = document.querySelector(selector);
		if (element instanceof HTMLElement) {
			element.textContent = message;
			element.classList.toggle('text-red-700', error);
			element.classList.toggle('text-stone-500', !error);
		}
	};

	document.querySelector('[data-json-format]')?.addEventListener('click', () => transformJson(2));
	document.querySelector('[data-json-minify]')?.addEventListener('click', () => transformJson(0));
	function transformJson(spaces: number) {
		const input = byId('json-input');
		if (!(input instanceof HTMLTextAreaElement)) return;
		try {
			input.value = JSON.stringify(JSON.parse(input.value), null, spaces);
			setStatus('[data-json-status]', spaces ? '整形しました。' : '圧縮しました。');
		} catch (error) {
			setStatus('[data-json-status]', error instanceof Error ? `JSONが不正です: ${error.message}` : 'JSONが不正です。', true);
		}
	}

	document.querySelector('[data-url-encode]')?.addEventListener('click', () => transformUrl('encode'));
	document.querySelector('[data-url-decode]')?.addEventListener('click', () => transformUrl('decode'));
	function transformUrl(mode: 'encode' | 'decode') {
		const input = byId('url-input');
		if (!(input instanceof HTMLTextAreaElement)) return;
		try {
			input.value = mode === 'encode' ? encodeURIComponent(input.value) : decodeURIComponent(input.value);
			setStatus('[data-url-status]', mode === 'encode' ? 'エンコードしました。' : 'デコードしました。');
		} catch {
			setStatus('[data-url-status]', '変換できない文字列です。%を含む形式を確認してください。', true);
		}
	}

	document.querySelectorAll('[data-copy-target]').forEach((button) => {
		button.addEventListener('click', async () => {
			const targetId = button.getAttribute('data-copy-target');
			const target = targetId ? byId(targetId) : null;
			if (!(target instanceof HTMLTextAreaElement)) return;
			try {
				await navigator.clipboard.writeText(target.value);
				const status = targetId === 'json-input' ? '[data-json-status]' : '[data-url-status]';
				setStatus(status, 'クリップボードにコピーしました。');
			} catch {
				target.select();
				setStatus(targetId === 'json-input' ? '[data-json-status]' : '[data-url-status]', '選択しました。コピー操作を行ってください。');
			}
		});
	});

	const unixInput = byId('unix-input');
	const dateInput = byId('date-input');
	const toLocalInputValue = (date: Date) => {
		const local = new Date(date.getTime() - date.getTimezoneOffset() * 60_000);
		return local.toISOString().slice(0, 19);
	};
	function setNow() {
		const now = new Date();
		if (unixInput instanceof HTMLInputElement) unixInput.value = String(Math.floor(now.getTime() / 1000));
		if (dateInput instanceof HTMLInputElement) dateInput.value = toLocalInputValue(now);
		setStatus('[data-time-status]', `ISO: ${now.toISOString()}`);
	}
	document.querySelector('[data-time-now]')?.addEventListener('click', setNow);
	unixInput?.addEventListener('input', () => {
		if (!(unixInput instanceof HTMLInputElement) || !(dateInput instanceof HTMLInputElement)) return;
		const seconds = Number(unixInput.value);
		const date = new Date(seconds * 1000);
		if (!unixInput.value || !Number.isFinite(seconds) || Number.isNaN(date.getTime())) return setStatus('[data-time-status]', '有効なUnix時刻を入力してください。', true);
		dateInput.value = toLocalInputValue(date);
		setStatus('[data-time-status]', `ISO: ${date.toISOString()}`);
	});
	dateInput?.addEventListener('input', () => {
		if (!(unixInput instanceof HTMLInputElement) || !(dateInput instanceof HTMLInputElement)) return;
		const date = new Date(dateInput.value);
		if (!dateInput.value || Number.isNaN(date.getTime())) return;
		unixInput.value = String(Math.floor(date.getTime() / 1000));
		setStatus('[data-time-status]', `ISO: ${date.toISOString()}`);
	});
	setNow();

	const counter = byId('counter-input');
	function updateCounts() {
		if (!(counter instanceof HTMLTextAreaElement)) return;
		const value = counter.value;
		byId('counter-chars')!.textContent = String(Array.from(value).length);
		byId('counter-no-space')!.textContent = String(Array.from(value.replace(/\s/g, '')).length);
		byId('counter-lines')!.textContent = String(value ? value.split(/\r\n|\r|\n/).length : 0);
		byId('counter-bytes')!.textContent = String(new TextEncoder().encode(value).length);
	}
	counter?.addEventListener('input', updateCounts);

	type Xxhash = Awaited<ReturnType<typeof createXxhash>>;
	let hasher: Xxhash | null = null;
	let hashMode: 'text' | 'file' = 'text';
	const hash32Output = byId('hash-32-output');
	const hash64Output = byId('hash-64-output');
	const hashTextInput = byId('hash-text-input');
	const hashFileInput = byId('hash-file-input');
	const writeHashes = (hash32: number, hash64: bigint) => {
		if (hash32Output) hash32Output.textContent = hash32.toString(16).padStart(8, '0');
		if (hash64Output) hash64Output.textContent = hash64.toString(16).padStart(16, '0');
	};
	const resetHashes = () => {
		if (hash32Output) hash32Output.textContent = '—';
		if (hash64Output) hash64Output.textContent = '—';
	};
	async function hashText() {
		if (!hasher || !(hashTextInput instanceof HTMLTextAreaElement)) return;
		const value = hashTextInput.value;
		if (!value) {
			resetHashes();
			return setStatus('[data-hash-status]', 'テキストを入力してください。');
		}
		writeHashes(hasher.h32(value), hasher.h64(value));
		setStatus('[data-hash-status]', `${new TextEncoder().encode(value).length.toLocaleString()}バイトをWASMで計算しました。`);
	}
	async function hashFile(file: File) {
		if (!hasher) return;
		setStatus('[data-hash-status]', `${file.name} を計算しています…`);
		const stream32 = hasher.create32();
		const stream64 = hasher.create64();
		const reader = file.stream().getReader();
		while (true) {
			const { done, value } = await reader.read();
			if (done) break;
			stream32.update(value);
			stream64.update(value);
		}
		writeHashes(stream32.digest(), stream64.digest());
		setStatus('[data-hash-status]', `${file.name}（${file.size.toLocaleString()}バイト）をWASMで計算しました。`);
	}
	document.querySelectorAll<HTMLButtonElement>('[data-hash-tab]').forEach((tab) => {
		tab.addEventListener('click', () => {
			const mode = tab.dataset.hashTab;
			if (mode !== 'text' && mode !== 'file') return;
			hashMode = mode;
			document.querySelectorAll<HTMLButtonElement>('[data-hash-tab]').forEach((item) => item.setAttribute('aria-selected', String(item === tab)));
			document.querySelectorAll<HTMLElement>('[data-hash-panel]').forEach((panel) => { panel.hidden = panel.dataset.hashPanel !== mode; });
			resetHashes();
			setStatus('[data-hash-status]', mode === 'text' ? 'テキストを入力してください。' : 'ファイルを選択してください。');
		});
	});
	hashTextInput?.addEventListener('input', hashText);
	hashFileInput?.addEventListener('change', () => {
		if (hashMode !== 'file' || !(hashFileInput instanceof HTMLInputElement)) return;
		const file = hashFileInput.files?.[0];
		if (file) hashFile(file).catch(() => setStatus('[data-hash-status]', 'ファイルを読み込めませんでした。', true));
	});
	createXxhash()
		.then((instance) => {
			hasher = instance;
			setStatus('[data-hash-status]', 'WASMの準備ができました。テキストを入力してください。');
		})
		.catch(() => setStatus('[data-hash-status]', 'このブラウザではWebAssemblyを利用できません。', true));
</script>
