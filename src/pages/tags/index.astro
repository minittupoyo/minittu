---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';

const allPosts = await getCollection('blog', ({ data }) => {
	return import.meta.env.DEV ? true : !data.draft;
});

const tagStats = [...new Set(allPosts.flatMap((post) => post.data.tags))]
	.map((tag) => {
		const posts = allPosts
			.filter((post) => post.data.tags.includes(tag))
			.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

		return {
			name: tag,
			count: posts.length,
			latestPost: posts[0],
		};
	})
	.sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, 'ja'));
---

<Layout title="タグ一覧 | みにっつのブログ" description="みにっつのブログで使われているタグの一覧です。">
	<div class="space-y-10">
		<header class="py-6 border-b border-stone-200/60">
			<a
				href="/"
				class="inline-flex items-center gap-1.5 text-xs font-semibold text-stone-500 hover:text-stone-900 transition-colors duration-200 mb-4"
			>
				<Icon name="tabler:arrow-left" class="w-3.5 h-3.5" aria-hidden="true" />
				ホームに戻る
			</a>
			<div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
				<div>
					<h1 class="text-3xl font-extrabold text-stone-900 tracking-tight">
						タグ一覧
					</h1>
					<p class="mt-2 text-sm text-stone-500">
						{tagStats.length}件のタグがあります。
					</p>
				</div>
				<p class="text-xs text-stone-400">
					記事数の多い順に表示しています。
				</p>
			</div>
		</header>

		{
			tagStats.length === 0 ? (
				<p class="text-sm text-stone-500">タグがありません。</p>
			) : (
				<div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
					{tagStats.map((tag) => (
						<a
							href={`/tags/${encodeURIComponent(tag.name)}`}
							class="group rounded-lg border border-stone-200/80 bg-white p-4 transition-all duration-150 hover:border-stone-300 hover:bg-stone-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-400 focus-visible:ring-offset-2"
						>
							<div class="flex items-start justify-between gap-3">
								<h2 class="min-w-0 text-base font-bold text-stone-900 group-hover:text-stone-700">
									<span class="text-stone-400">#</span>
									<span class="break-words">{tag.name}</span>
								</h2>
								<span class="shrink-0 rounded-md bg-stone-100 px-2 py-0.5 text-xs font-semibold text-stone-500">
									{tag.count}件
								</span>
							</div>
							{tag.latestPost && (
								<p class="mt-3 text-xs leading-relaxed text-stone-500 line-clamp-2">
									最新: {tag.latestPost.data.title}
								</p>
							)}
						</a>
					))}
				</div>
			)
		}
	</div>
</Layout>
