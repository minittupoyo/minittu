---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

// 全ての記事を取得し、下書きを除外（開発環境では下書きも表示）
const allPosts = await getCollection("blog", ({ data }) => {
    return import.meta.env.DEV ? true : !data.draft;
});

// 日付の新しい順にソートし、最新の6件のみ表示
const posts = allPosts
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
    .slice(0, 6);

// タグを記事数順に集計し、トップページでは主要タグだけを表示
const tagStats = [...new Set(allPosts.flatMap((post) => post.data.tags))]
    .map((tag) => ({
        name: tag,
        count: allPosts.filter((post) => post.data.tags.includes(tag)).length,
    }))
    .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, "ja"));
const visibleTags = tagStats.slice(0, 10);

// 日付フォーマットのヘルパー
const formatDate = (date: Date) => {
    return date.toLocaleDateString("ja-JP", {
        year: "numeric",
        month: "long",
        day: "numeric",
    });
};
---

<Layout
    title="みにっつのブログ"
    description="みにっつの超個人的忘備録。日記や開発のメモを置いています。"
>
    <div class="space-y-12">
        <!-- ヒーローセクション / イントロ -->
        <section class="py-6 border-b border-stone-200/60">
            <h1
                class="text-3xl font-extrabold tracking-tight text-stone-900 sm:text-4xl"
            >
                みにっつのブログ
            </h1>
            <p class="mt-4 text-base text-stone-600 max-w-2xl leading-relaxed">
                みにっつの超個人的忘備録。日々の雑多なことや、サーバー・開発のメモなどをダラダラと書き残しておく場所です。
            </p>
        </section>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
            <!-- メインコンテンツ：記事一覧 -->
            <div class="md:col-span-3 space-y-10">
                <div class="flex items-center justify-between gap-3 mb-6">
                    <h2
                        class="text-xs font-bold uppercase tracking-wider text-stone-400"
                    >
                        最新の記事
                    </h2>
                    <a
                        href="/posts"
                        class="text-xs font-semibold text-stone-500 hover:text-stone-900 transition-colors duration-150"
                    >
                        すべての記事
                    </a>
                </div>

                {
                    posts.length === 0 ? (
                        <p class="text-stone-500">記事がありません。</p>
                    ) : (
                        <div class="space-y-6">
                            {posts.map((post) => (
                                <article class="group flex flex-col md:flex-row gap-6 bg-white border border-stone-200/80 rounded-xl p-5 transition-all duration-200 hover:border-stone-300 hover:shadow-[0_2px_8px_rgba(0,0,0,0.02)] relative">
                                    {post.data.heroImage && (
                                        <div class="md:w-1/3 shrink-0 rounded-lg overflow-hidden aspect-[16/9] bg-stone-50 border border-stone-100/80">
                                            <Image
                                                src={post.data.heroImage}
                                                alt={post.data.title}
                                                class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
                                                width={600}
                                                height={338}
                                            />
                                        </div>
                                    )}
                                    <div class="flex-1 flex flex-col">
                                        <div class="flex items-center gap-2 text-xs text-stone-500 mb-2">
                                            <time
                                                datetime={post.data.date.toISOString()}
                                            >
                                                {formatDate(post.data.date)}
                                            </time>
                                            {post.data.draft && (
                                                <span class="px-1.5 py-0.5 bg-amber-100 text-amber-800 rounded-sm font-medium scale-90">
                                                    下書き
                                                </span>
                                            )}
                                        </div>

                                        <h3 class="text-lg font-bold text-stone-900 group-hover:text-stone-600 transition-colors duration-200 line-clamp-2 mb-2">
                                            <a
                                                href={`/posts/${post.id}`}
                                                class="after:absolute after:inset-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-stone-400 focus-visible:ring-offset-2 rounded-sm"
                                            >
                                                {post.data.title}
                                            </a>
                                        </h3>

                                        <p class="text-sm text-stone-600 line-clamp-2 leading-relaxed mb-4 flex-1">
                                            {post.data.description}
                                        </p>

                                        <div class="flex flex-wrap gap-1.5 mt-auto relative z-10">
                                            {post.data.tags.map((tag) => (
                                                <a
                                                    href={`/tags/${encodeURIComponent(tag)}`}
                                                    class="inline-flex items-center rounded-md bg-stone-100 px-2 py-0.5 text-xs font-medium text-stone-600 hover:bg-stone-200 transition-colors duration-150"
                                                >
                                                    #{tag}
                                                </a>
                                            ))}
                                        </div>
                                    </div>
                                </article>
                            ))}
                        </div>
                    )
                }
            </div>

            <!-- サイドバー：タグ一覧 -->
            <aside class="md:col-span-1 space-y-6">
                <nav aria-label="タグ一覧">
                    <div class="flex items-center justify-between gap-3 mb-4">
                        <h2
                            class="text-xs font-bold uppercase tracking-wider text-stone-400"
                        >
                            タグ
                        </h2>
                        <a
                            href="/tags"
                            class="text-xs font-semibold text-stone-500 hover:text-stone-900 transition-colors duration-150"
                        >
                            すべて
                        </a>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        {
                            visibleTags.map((tag) => (
                                <a
                                    href={`/tags/${encodeURIComponent(tag.name)}`}
                                    class="inline-flex items-center gap-1 rounded-md bg-white border border-stone-200/80 px-2.5 py-1 text-xs font-medium text-stone-700 hover:border-stone-400 hover:bg-stone-50 transition-all duration-150"
                                >
                                    <span>#{tag.name}</span>
                                    <span class="text-stone-400">{tag.count}</span>
                                </a>
                            ))
                        }
                    </div>
                    {
                        tagStats.length > visibleTags.length && (
                            <a
                                href="/tags"
                                class="mt-4 inline-flex items-center justify-center w-full rounded-md border border-stone-200 bg-stone-100/70 px-3 py-2 text-xs font-semibold text-stone-600 hover:border-stone-300 hover:bg-white hover:text-stone-900 transition-all duration-150"
                            >
                                全{tagStats.length}件のタグを見る
                            </a>
                        )
                    }
                </nav>
            </aside>
        </div>
    </div>
</Layout>
